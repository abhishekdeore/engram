# ─────────────────────────────────────────────
# Neo4j Connection
# ─────────────────────────────────────────────
# For Neo4j Desktop: bolt://localhost:7687
# For Neo4j AuraDB: neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ─────────────────────────────────────────────
# Auth (Phase 1)
# ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_this_to_a_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─────────────────────────────────────────────
# Embeddings (Phase 2)
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─────────────────────────────────────────────
# Redis Cache (Phase 2)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
EMBEDDING_CACHE_TTL_SECONDS=3600

# ─────────────────────────────────────────────
# MCP Server (Phase 4)
# ─────────────────────────────────────────────
# The user identity used by the MCP server when writing/querying memory.
# Must match the userId you use with the HTTP API.
# Keep this stable — it is the key that links memory across all LLM providers.
# Can also be set in claude_desktop_config.json under env.MCP_USER_ID.
MCP_USER_ID=your-stable-user-id
